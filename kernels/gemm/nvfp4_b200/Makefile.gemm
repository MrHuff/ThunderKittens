GPU := B200

# PyTorch extension mode — GEMM with unique module name to avoid _C conflict
SRC := nvfp4_b200_gemm.cu
OUT := _C_nv_gemm$(shell python3 -c "import sysconfig; print(sysconfig.get_config_var('EXT_SUFFIX'))")
CMD := echo "built"
NVCCFLAGS := -DTORCH_COMPILE
CONFIG := pytorch

include ../../common.mk

NVCCFLAGS += -DTORCH_EXTENSION_NAME=_C_nv_gemm
